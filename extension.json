{
  "id": "users",
  "name": "Users",
  "version": "0.1.0",
  "description": "提供用户资料、用户组、权限分配与封禁管理能力。",
  "icon": "fas fa-users",
  "category": "foundation",
  "authors": [
    "Bias"
  ],
  "dependencies": [
    "core"
  ],
  "provides": [
    "users",
    "profiles",
    "groups",
    "suspension"
  ],
  "django": {
    "app_config": "bias_ext_users.backend.apps.UsersExtensionConfig",
    "app_label": "users",
    "migration_module": "bias_ext_users.backend.django_migrations"
  },
  "backend": {
    "entry": "bias_ext_users.backend.ext"
  },
  "frontend": {
    "admin_entry": "frontend/admin/index.js",
    "forum_entry": "frontend/forum/index.js"
  },
  "extra": {
    "auto_install": true,
    "auto_enable": true,
    "protected": true,
    "protected_reason": "用户、用户组、权限与账号安全是系统基础域，不能作为普通功能扩展停用或卸载。",
    "frontend_boot": {
      "admin": true
    }
  },
  "security": {
    "capabilities_notice": "User domain extension; owns authentication, profile, group, permission, and account security surfaces."
  }
}
